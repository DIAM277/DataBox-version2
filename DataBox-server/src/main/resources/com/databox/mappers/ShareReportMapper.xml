			</if>
			<if test="bean.reason != null">
				 reason,
			</if>
			<if test="bean.status != null">
				 status,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.reportId!=null">
				 #{bean.reportId},
			</if>
			<if test="bean.shareId!=null">
				 #{bean.shareId},
			</if>
			<if test="bean.fileId!=null">
