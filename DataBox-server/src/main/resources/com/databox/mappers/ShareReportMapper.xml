 		 </set>
 		 where report_id=#{reportId}
	</update>

	<!-- 根据ReportId删除-->
	<delete id="deleteByReportId">
		delete from share_report where report_id=#{reportId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByReportId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from share_report where report_id=#{reportId}
	</select>

</mapper>