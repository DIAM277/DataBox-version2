			<if test="bean.loginIp != null">
				 login_ip,
			</if>
			<if test="bean.loginLocation != null">
				 login_location,
			</if>
			<if test="bean.loginTime != null">
				 login_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.userId!=null">
