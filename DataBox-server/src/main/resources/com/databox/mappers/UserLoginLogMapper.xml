			<if test="bean.loginLocation!=null">
				 #{bean.loginLocation},
			</if>
			<if test="bean.loginTime!=null">
				 #{bean.loginTime},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="com.databox.entity.po.UserLoginLog">
